{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "imagePrompt",
      "type": "promptString",
      "description": "Describe the image (e.g. 'a rainy Tokyo alley at night, neon, 35mm film')"
    },
    {
      "id": "jsonFile",
      "type": "promptString",
      "description": "Path to JSON sidecar (e.g. output/image-1234567890.json)"
    }
  ],
  "tasks": [
    {
      "label": "Start Server",
      "type": "shell",
      "command": "npm start",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "running at",
          "endsPattern": "running at"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Generate Image",
      "type": "shell",
      "command": "node generate.js \"${input:imagePrompt}\"",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Regenerate from JSON",
      "type": "shell",
      "command": "node generate.js --json \"${input:jsonFile}\"",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
